# Supabase Configuration
# Get these values from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google OAuth Configuration (for sync-google-calendar)
# Create OAuth credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here

# Firebase/GCP Configuration (if using Firestore or other GCP services)
# Download service account key from Google Cloud Console
GCP_PROJECT_ID=your-gcp-project-id
GCP_PRIVATE_KEY=your-private-key-here
GCP_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Node Environment
NODE_ENV=development
